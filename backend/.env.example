# -------------------------------
# Database
# -------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=sportflow
DB_PASSWORD=sportflow
DB_DATABASE=sportflow
DB_SYNCHRONIZE=true

# -------------------------------
# Files (paths relative to backend folder)
# -------------------------------
FILES_UPLOAD_PATH=./uploads
AVATAR_STORAGE_PATH=./uploads/avatars
ACTIVITIES_STORAGE_PATH=./uploads/activities

# -------------------------------
# Images General Configuration
# -------------------------------

# Max image size in bytes (10 MB)
IMAGES_MAX_SIZE=10485760

# Allowed file extensions (case-insensitive)
IMAGES_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,bmp,tiff,ico,webp

# Allowed MIME types
IMAGES_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/bmp,image/tiff,image/ico,image/webp
